// ────────────── Output Configuration ──────────────
// You can run `niri msg outputs` to get the correct name for your displays.
// You will have to remove "/-" and edit it before it takes effect.
// https://github.com/YaLTeR/niri/wiki/Configuration:-Outputs

output "DP-1" {
    mode "3840x2160@143.999" // Set resolution and refresh rate
    scale 1.25 // No scaling (use 2 for HiDPI)
    focus-at-startup
    variable-refresh-rate on-demand=true
}

output "HDMI-A-1" {
    mode "3840x2160@59.997"
    scale 1
    position x=0 y=0
}