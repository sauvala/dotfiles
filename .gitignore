.config/Bitwarden/
.config/mozilla/
.config/google-chrome/
.config/chromium/
.ssh/id_*
.ssh/known_hosts
.ssh/config.local
.gnupg/
.pki/
.netrc
.aws/

# ── Machine-specific git identity (never commit) ───────────────────────
.gitconfig.local
.gitconfig-work

# ── Application state ─────────────────────────────────────────────────
.cache/
.local/
.var/
.vscode/
.config/Code/
.config/discord/
.config/Slack/
.config/spotify/
.config/pulse/
.config/pipewire/
.config/dconf/
.config/menus/
