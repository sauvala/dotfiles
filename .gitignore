.config/mimeapps.list

# ── Shell history & state ──────────────────────────────────────────────
.bash_history
.zsh_history
.python_history
.lesshst
.viminfo
.local/share/fish/fish_history
.zcompdump*

# ── Claude Code ────────────────────────────────────────────────────────
.claude.json
.claude/settings.local.json

# ── Emacs generated/cache ─────────────────────────────────────────────
